df = pd.DataFrame(
    {
        "Name": ["Braund, Mr. Owen Harris", "Allen, Mr. William Henry", "Bonnell, Miss. Elizabeth"],
        "Age": [22, 35, 58], 
        "Sex": ["male", "male", "female"]
    }
)


df





# Refer to data in column Age 
df["Age"]


# Create a Series from scratch
ages = pd.Series([22, 35, 58], name = "Age")


ages





# maximum age of the passengers from the Age column 
df["Age"].max() 


# max from the Series we created 
ages.max()


# Some basic statistics of the numerical data of the df. 
df.describe()





