   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "\n",
    "sc = ax.scatter([1, 2], [1, 2], c=[1, 2])\n",
    "ax.set_ylabel(\"YLabel\", loc=\"top\")\n",
    "ax.set_xlabel(\"XLabel\", loc=\"left\")\n",
    "cbar = fig.colorbar(sc)\n",
    "cbar.set_label(\"ZLabel\", loc=\"top\")"
   ]
